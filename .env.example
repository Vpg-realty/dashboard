# Copy this file to `.env` on the office machine. Never commit `.env`.

# JSON object mapping each GHL location ID to its Private Integration token.
# Get tokens in GHL: Sub-account → Settings → Private Integrations → Create.
# Required scopes: contacts.readonly, conversations.readonly,
# opportunities.readonly, users.readonly.
GHL_TOKENS={"locationId1":"pit_xxx","locationId2":"pit_yyy"}

# Server port — leave at 3000 unless something else is using it.
PORT=3000

# In-memory cache TTL for the aggregated snapshot. 15s = browser refreshes
# at most every 15 seconds even if the page is reloaded a hundred times.
SNAPSHOT_TTL_SECONDS=15
