# Reference only. The dashboard does NOT read a local .env at runtime —
# the GHL_TOKENS value lives in GitHub Secrets and is consumed by the
# Actions workflow at build time.
#
# To set the secret:
#   gh secret set GHL_TOKENS --body '{"<locationId>":"pit_xxx", ...}'
#
# Or via GitHub UI: repo → Settings → Secrets and variables → Actions → New
# repository secret. Name: GHL_TOKENS. Value: a JSON object mapping each
# sub-account location ID to its Private Integration Token.
#
# How to get each PIT in GHL:
#   Sub-account → Settings → Private Integrations → Create.
#   Required scopes: contacts.readonly, conversations.readonly,
#   opportunities.readonly, users.readonly.
#
# How to get each location ID:
#   Look at the GHL URL while inside the sub-account: /location/{id}/...
#
# Example value (one entry per sub-account, 13 total for VPG's setup):
GHL_TOKENS={"abc123":"pit_xxx","def456":"pit_yyy"}

# For local snapshot testing only. Run:
#   GHL_TOKENS='...' npm run snapshot
# to generate public/data.json on your machine.
